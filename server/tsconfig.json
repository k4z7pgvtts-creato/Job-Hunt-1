{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,           // ← مهم جداً
    "emitDecoratorMetadata": true             // ← مهم جداً
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}